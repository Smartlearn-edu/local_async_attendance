<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/async_attendance/db" VERSION="20260530" COMMENT="XMLDB file for Moodle local_async_attendance plugin"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_async_attendance" COMMENT="Stores daily attendance records generated by the async log scraper">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="The Moodle user"/>
        <FIELD NAME="attendance_date" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Unix timestamp for midnight of the attendance day"/>
        <FIELD NAME="status" TYPE="char" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="PRESENT, ABSENT, or LATE"/>
        <FIELD NAME="total_events" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Number of log events recorded that day"/>
        <FIELD NAME="first_event_time" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Timestamp of first activity"/>
        <FIELD NAME="last_event_time" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Timestamp of last activity"/>
        <FIELD NAME="source" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="log_scraper" SEQUENCE="false" COMMENT="Source of the record"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Record creation timestamp"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="user_date_idx" UNIQUE="true" FIELDS="userid, attendance_date"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
